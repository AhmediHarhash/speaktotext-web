{
  "name": "@hekax/marketing-site",
  "version": "0.0.0",
  "private": true,
  "description": "Premium marketing site for the SpeakToText desktop app.",
  "scripts": {
    "build": "next build",
    "dev": "next dev -p 3100",
    "start": "next start -p 3100",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "asset:audit": "node scripts/audit-owned-assets.mjs",
    "r2:bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap-r2.ps1",
    "r2:upload": "powershell -ExecutionPolicy Bypass -File scripts/upload-owned-assets.ps1"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@opennextjs/cloudflare": "^1.19.7",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "clsx": "^2.1.1",
    "eslint-config-next": "^15.5.16",
    "framer-motion": "^11.11.17",
    "gsap": "^3.13.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.462.0",
    "maath": "^0.10.8",
    "next": "^15.5.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.184.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "wrangler": "^4.88.0"
  }
}
